    {
      "name": "06 — Seguridad y casos negativos",
      "item": [
        {
          "name": "Sin token → 401",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "description": "Espera HTTP 401"
          },
          "response": []
        },
        {
          "name": "JWT corrupto → 401",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer not.a.real.jwt" }],
            "url": "{{base_url}}/auth/me",
            "description": "Espera HTTP 401"
          },
          "response": []
        },
        {
          "name": "Token cliente en ruta admin → 403",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": "{{base_url}}/admin/customers",
            "description": "Espera HTTP 403 Forbidden"
          },
          "response": []
        },
        {
          "name": "Security headers (verificar en Headers de respuesta)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/catalog",
            "description": "Verificar en la pestaña Headers de la respuesta: X-Content-Type-Options, X-Frame-Options, Referrer-Policy"
          },
          "response": []
        },
        {
          "name": "Rate limit login (ejecutar 6 veces rápido → 6to da 429)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@tienda.com\",\n  \"password\": \"wrong\"\n}"
            },
            "url": "{{base_url}}/auth/login",
            "description": "Ejecutar este request 6 veces seguidas (Ctrl+Enter × 6). El 6to intento debe devolver 429 Too Many Requests"
          },
          "response": []
        }
      ]
